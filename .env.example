DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
FINNHUB_API_KEY="get-a-free-key-at-finnhub.io"

# generate with: npx auth secret  OR  openssl rand -base64 32
AUTH_SECRET="random-32-byte-base64-string"

# Google OAuth (Cloud Console -> APIs & Services -> Credentials)
AUTH_GOOGLE_ID="xxxxxxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxxxxxx"

# comma-separated list of Google accounts allowed to sign in
ALLOWED_EMAILS="you@example.com,friend@example.com"
