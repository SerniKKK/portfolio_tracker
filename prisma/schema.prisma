// Prisma schema for Portfolio Tracker
// Local dev + production: PostgreSQL (Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  STOCK
  ETF
  CRYPTO
  CASH
}

enum Currency {
  PLN
  EUR
  USD
}

// --- Auth.js (NextAuth) v5 tables ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts          Account[]
  sessions          Session[]
  positions         Position[]
  portfolioSnapshot PortfolioSnapshot[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// --- Domain tables ---

model Position {
  id               String    @id @default(cuid())
  userId           String
  name             String
  ticker           String
  assetType        AssetType
  quantity         Float
  purchasePrice    Float
  purchaseCurrency Currency
  purchaseDate     DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ticker])
}

model PriceCache {
  id        String   @id @default(cuid())
  ticker    String
  price     Float
  currency  Currency
  fetchedAt DateTime @default(now())

  @@unique([ticker, currency])
}

model PortfolioSnapshot {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  totalValuePLN Float
  totalCostPLN  Float
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model FxRate {
  currency  Currency @id
  rateToPLN Float
  fetchedAt DateTime @default(now())
}
